# Database connection string
# For PostgreSQL (production): postgresql+asyncpg://user:password@host:5432/dbname
# For SQLite (local dev): sqlite+aiosqlite:///./saas.db
DATABASE_URL=sqlite+aiosqlite:///./saas.db

# AES-256 encryption key for Google Ads credentials (Fernet key, base64-encoded 32 bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# JWT signing secret
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your-jwt-secret-here

# Google OAuth 2.0 Client ID (for verifying frontend login tokens)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SuperAdmin email — this user gets superadmin role on first login
SUPERADMIN_EMAIL=thequantpartners@gmail.com

# Allowed frontend origins (comma-separated)
FRONTEND_ORIGINS=http://localhost:3000

# Lemon Squeezy integration
LEMONSQUEEZY_API_KEY=your-api-key-here
LEMONSQUEEZY_STORE_ID=your-store-id-here
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret-here
